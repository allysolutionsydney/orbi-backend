# ── ORBI Backend Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your keys
# NEVER commit .env to git

# OpenAI — used for chat (GPT-4o), STT (Whisper), TTS, and embeddings
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini           # gpt-4o-mini (fast) or gpt-4o (smarter)
OPENAI_TTS_VOICE=nova              # alloy | echo | fable | onyx | nova | shimmer

# Supabase — database + vector memory
# https://supabase.com → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # Service role key (not anon key)

# App config
ORBI_SECRET_KEY=your-random-secret-key-here
ORBI_ENV=development               # development | production
ALLOWED_ORIGINS=*
